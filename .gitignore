# macOS
.DS_Store

# Xcode — user & build artifacts
build/
DerivedData/
*.xcuserstate
*.xcuserdatad
xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Xcode workspace/user cruft (the .xcodeproj itself IS committed — see project.yml)
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcscmblueprint

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# CocoaPods / Carthage (not used, but ignored defensively)
Pods/
Carthage/Build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png

# Secrets — never commit real proxy keys/endpoints
*.xcconfig.local
Secrets.plist

# Scratch
*.orig

# Local agent orchestration state
.mavis/
