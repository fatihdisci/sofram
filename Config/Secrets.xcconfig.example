// Secrets.xcconfig.example — template for the local secrets file.
//
// Copy this file to Secrets.xcconfig.local (same directory) and replace the
// placeholder with the real value. Secrets.xcconfig.local is gitignored and
// MUST NEVER be committed.
//
//     cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig.local
//
// CALP_PROXY_API_KEY is the shared client key the app sends in the `x-calp-key`
// header to the AI proxy. It must match the proxy's CALP_CLIENT_KEY (Vercel
// environment variable). Info.plist references it as $(CALP_PROXY_API_KEY).

CALP_PROXY_API_KEY = replace-with-calp-client-key
