// Secrets.xcconfig — committed base config for Calp secrets.
//
// This file is safe to commit: it only declares an empty default and then
// optionally pulls in the real values from Secrets.xcconfig.local, which is
// gitignored and never committed.
//
// Setup: copy Secrets.xcconfig.example to Secrets.xcconfig.local and fill in
// the real value. See proxy/README.md for how CALP_PROXY_API_KEY maps to the
// proxy's CALP_CLIENT_KEY.

// Empty default so the build still succeeds on a fresh checkout without the
// local override present (the app then runs unauthenticated against the proxy).
CALP_PROXY_API_KEY =

// Optional local override (relative to this file's directory). The `?` makes
// the include silent when the file is absent — e.g. on CI or a fresh clone.
#include? "Secrets.xcconfig.local"
