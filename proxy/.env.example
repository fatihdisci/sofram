OPENAI_API_KEY=replace-with-openai-api-key
# Shared client key. CALP_CLIENT_KEY is canonical; the pre-rename
# CALORISOR_CLIENT_KEY is still read as a fallback during the transition. brand-keep
CALP_CLIENT_KEY=replace-with-random-client-key
# Optional daily spend ceiling (microusd). CALP_DAILY_COST_ALERT_MICROUSD is
# canonical; CALORISOR_DAILY_COST_ALERT_MICROUSD is honored as a fallback. brand-keep
# CALP_DAILY_COST_ALERT_MICROUSD=10000000
UPSTASH_REDIS_REST_URL=replace-with-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token
# Secret salt used to hash the anonymous installation id before it is used as a
# rate-limit key. Required — the function returns 502 if it is unset.
INSTALLATION_HASH_SALT=replace-with-random-installation-salt
# Optional: set to "true" once every shipped client sends the installation id
# header, to reject requests that omit it instead of falling back to IP hashing.
# REQUIRE_INSTALLATION_ID=true

# --- Apple StoreKit server-side verification (Calp Pro) ---
# The proxy verifies the client's StoreKit signedTransactionInfo JWS with
# Apple's official @apple/app-store-server-library before granting Pro. See
# README.md → "Apple StoreKit (Calp Pro) verification" for the full setup.
#
# Bundle id the transaction must be signed for. Defaults to com.fatih.calp when
# unset, but set it explicitly in production.
APPLE_BUNDLE_ID=com.fatih.calp
# Base64 DER of Apple Root CA - G3 (comma/newline separated if you add more).
# Prepare with: base64 -i AppleRootCA-G3.cer   (single line, no newlines).
APPLE_ROOT_CERTIFICATES=replace-with-base64-der-of-AppleRootCA-G3
# Environments to accept, comma separated: Sandbox, Production, or both.
# Sandbox = TestFlight/dev builds. Production = App Store. Unset ⇒ both
# (Production first, then Sandbox).
APPLE_STOREKIT_ENVIRONMENT=Sandbox
# Numeric App Store app id (adamId). REQUIRED to verify Production transactions;
# leave unset for Sandbox-only testing.
# APPLE_APP_APPLE_ID=6790000000
# Optional: "true" enables OCSP revocation + live-date checks (needs outbound
# network egress). Leave unset/false on the edge-adjacent serverless runtime.
# APPLE_ENABLE_ONLINE_CHECKS=false
