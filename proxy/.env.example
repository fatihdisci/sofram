OPENAI_API_KEY=replace-with-openai-api-key
CALORISOR_CLIENT_KEY=replace-with-random-client-key
UPSTASH_REDIS_REST_URL=replace-with-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token
# Secret salt used to hash the anonymous installation id before it is used as a
# rate-limit key. Required — the function returns 502 if it is unset.
INSTALLATION_HASH_SALT=replace-with-random-installation-salt
# Optional: set to "true" once every shipped client sends the installation id
# header, to reject requests that omit it instead of falling back to IP hashing.
# REQUIRE_INSTALLATION_ID=true
