{
  "name": "Calp — Flat (Visual Nutrition Intelligence)",
  "note": "Values mirror Calp/Assets.xcassets/Colors (the source of truth at runtime). Flat, typography-led: no gradient, glass, emboss or physical-depth shadow. Hierarchy comes from fill, 1pt border and whitespace.",
  "color": {
    "light": {
      "bg-page": "#F6F4F0",
      "surface-raised": "#FFFFFF",
      "surface-flat": "#EFEEE9",
      "border-hairline": "#DEDCD6",
      "border-highlight": "#FFFFFF",
      "border-shadow": "#D0C9B9",
      "text-primary": "#151515",
      "text-secondary": "#5F5C57",
      "text-muted": "#8C8984",
      "accent-fill": "#D3442B",
      "accent-fill-pressed": "#A83220",
      "accent-text": "#A83220",
      "on-accent": "#FFFFFF",
      "accent-tint-bg": "#F9E2DD",
      "macro-protein": "#6A8F6B",
      "macro-carb": "#C08A3E",
      "macro-fat": "#B06458"
    },
    "dark": {
      "bg-page": "#111111",
      "surface-raised": "#1A1A1A",
      "surface-flat": "#161616",
      "border-hairline": "#343434",
      "border-highlight": "#453D30",
      "border-shadow": "#100E0B",
      "text-primary": "#F6F4F0",
      "text-secondary": "#B7B3AE",
      "text-muted": "#827E79",
      "accent-fill": "#E85B43",
      "accent-fill-pressed": "#F27C65",
      "accent-text": "#F27C65",
      "on-accent": "#141414",
      "accent-tint-bg": "#3A201C",
      "macro-protein": "#8FB791",
      "macro-carb": "#D9A96A",
      "macro-fat": "#CE8A7E"
    },
    "contrast_notes": {
      "text-secondary-on-bg-page": "≥4.5:1 in both modes (AA, small text)",
      "accent-text-on-bg-page": "≥4.5:1 in both modes — use accent-fill only for icons/graphics/fills (3:1 non-text threshold), never as small body text color",
      "on-accent-on-accent-fill": "white/near-black label on the flat red — acceptable for icon/large button label",
      "border-highlight-border-shadow": "legacy tokens kept for API/asset compatibility; the flat system draws separation with border-hairline only"
    }
  },
  "typography": {
    "family-sans": "Geist Sans",
    "family-mono": "Geist Mono",
    "fallback-sans": "SF Pro",
    "fallback-mono": "SF Mono",
    "scale": {
      "display-large": { "font": "mono", "size": 58, "weight": "medium", "usage": "hero kalori sayısı (günlük halka)", "tabular": true },
      "display-numeric": { "font": "mono", "size": 34, "weight": "medium", "usage": "ikincil büyük sayılar (result totals, stat)" },
      "title": { "font": "sans", "size": 30, "weight": "semibold", "usage": "onboarding/paywall başlıkları" },
      "heading": { "font": "sans", "size": 22, "weight": "semibold", "usage": "ekran başlıkları / greeting" },
      "eyebrow": { "font": "sans", "size": 12, "weight": "semibold", "usage": "bölüm başlıkları (uppercase + tracking)" },
      "body": { "font": "sans", "size": 16, "weight": "regular", "usage": "gövde metni" },
      "label": { "font": "sans", "size": 14, "weight": "medium", "usage": "buton/etiket" },
      "caption": { "font": "sans", "size": 13, "weight": "regular", "usage": "ikincil metin, zaman damgası" },
      "numeric-small": { "font": "mono", "size": 15, "weight": "medium", "usage": "makro gram değerleri, kart içi kalori sayıları", "tabular": true }
    }
  },
  "spacing": { "unit": 4, "scale": [4, 8, 12, 16, 20, 24, 32] },
  "radius": {
    "control": 12,
    "card": 16,
    "raised-container": 24,
    "pill": 999
  },
  "surface_recipe": {
    "description": "Flat surfaces. No blur/emboss/inset shadow. Both raised and pressed surfaces are a solid fill plus a single 1pt border-hairline stroke; hierarchy is fill tone + whitespace + type.",
    "raised": { "fill": "surface-raised", "border": { "color": "border-hairline", "width": 1 } },
    "pressed": { "fill": "surface-flat", "border": { "color": "border-hairline", "width": 1 } },
    "press-feedback": "scaleEffect 0.97 + subtle flat surface-flat overlay on press; light haptic. No shadow transition."
  },
  "motion": {
    "dur-fast": 150,
    "dur-snap": 200,
    "dur-base": 300,
    "dur-slow": 500,
    "spring": { "response": 0.4, "dampingFraction": 0.75 },
    "note": "Motion kısa ve işlevsel; veri kaydı/analiz sonucunu destekler, arayüzü süslemez. Tetikleyici listesi mikro-etkilesimler.md."
  }
}
